{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "shijinze-copy",
  "version": "0.1.0",
  "identifier": "com.shijinze.clipboard-manager",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "剪切板",
        "width": 640,
        "height": 760,
        "minHeight": 360,
        "visible": false,
        "resizable": true,
        "alwaysOnTop": true,
        "transparent": true,
        "decorations": false,
        "skipTaskbar": true
      },
      {
        "label": "settings",
        "title": "设置",
        "url": "settings.html",
        "width": 560,
        "height": 600,
        "minWidth": 460,
        "minHeight": 420,
        "visible": false,
        "resizable": true,
        "center": true,
        "alwaysOnTop": false,
        "transparent": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/images/*", "$APPDATA/images/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "signingIdentity": "Clipboard Manager Dev"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
